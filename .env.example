# Microsoft Azure AD App Registration
# Register a multi-tenant app at https://portal.azure.com > App registrations
# Set "Supported account types" to "Accounts in any organizational directory and personal Microsoft accounts"
# Under "Authentication", enable "Allow public client flows"
# No client secret needed - this uses device code flow (public client)

O365_CLIENT_ID=YOUR_MULTI_TENANT_APP_CLIENT_ID

# Optional: restrict to a specific tenant (default: "common" for multi-tenant)
# O365_TENANT_ID=common
